#include <bits/stdc++.h>
using namespace std;

int main() {

    int n;
    cin >> n;

    vector<int> arr(n);

    for(int i = 0; i < n; i++){
        cin >> arr[i];
    }

    sort(arr.begin(), arr.end());

    int count = 1;

    for(int i = 0; i < n; i++){

        // Count duplicates
        while(i < n - 1 && arr[i] == arr[i + 1]){
            count++;
            i++;
        }

        cout << arr[i] << " " << count << endl;

        count = 1;
    }

    return 0;
}
