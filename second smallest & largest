#include <bits/stdc++.h>
using namespace std;

int main() {

    int n;
    cin >> n;

    vector<int> arr(n);

    // Input
    for(int i = 0; i < n; i++){
        cin >> arr[i];
    }

    // Sort the array
    sort(arr.begin(), arr.end());

    int secondSmallest = -1;
    int secondLargest = -1;

    // Find second smallest
    for(int i = 1; i < n; i++){
        if(arr[i] != arr[0]){
            secondSmallest = arr[i];
            break;
        }
    }
    // Find second largest
    for(int i = n - 2; i >= 0; i--){
        if(arr[i] != arr[n - 1]){
            secondLargest = arr[i];
            break;
        }
    }

    cout << "Second Smallest = " << secondSmallest << endl;
    cout << "Second Largest = " << secondLargest << endl;

    return 0;
}

