#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n;
    cin >> n;

    vector<int> arr(n);

    for(int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    int k;
    cin >> k;

    k = k % n;

    vector<int> ans(n);

    int j = 0;

    // Copy from k to n-1
    for(int i = k; i < n; i++)
    {
        ans[j] = arr[i];
        j++;
    }

    // Copy from 0 to k-1
    for(int i = 0; i < k; i++)
    {
        ans[j] = arr[i];
        j++;
    }

    for(int i = 0; i < n; i++)
    {
        cout << ans[i] << " ";
    }

    return 0;
}
